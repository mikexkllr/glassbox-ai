{
  "name": "glassbox",
  "version": "0.1.0",
  "description": "Glassbox — an interactive walkthrough that makes AI-written code effortless to understand.",
  "main": "./out/main/index.js",
  "author": "Glassbox",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "icons": "node scripts/gen-icons.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "3.1068.0",
    "@langchain/anthropic": "^1.4.1",
    "@langchain/aws": "^1.3.9",
    "@langchain/core": "^1.1.49",
    "@langchain/google-vertexai": "^2.1.31",
    "@langchain/langgraph": "^1.4.2",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "deepagents": "^1.10.2",
    "electron-updater": "^6.3.9",
    "parse-diff": "^0.12.0",
    "simple-git": "^3.36.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "framer-motion": "^12.40.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "ai.glassbox.app",
    "productName": "Glassbox",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [],
    "publish": {
      "provider": "github",
      "owner": "mikexkllr",
      "repo": "glassbox-ai"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "category": "Development",
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "maintainer": "Mike Keller"
    }
  }
}
